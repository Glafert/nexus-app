datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int     @id @default(autoincrement())
  username String
  password String
  role     String
  avatar   String?   // ← INI HARUS ADA
}

model Todo {
  id        String   @id @default(uuid())
  title     String
  column    String
  color     String
  userId    String
  createdAt DateTime @default(now())
}

model Board {
  userId String @id
  data   String
}